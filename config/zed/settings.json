// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "disable_ai": false,
  "minimap": {
    "show": "never",
  },
  "zoomed_padding": false,
  "buffer_font_fallbacks": ["Hack Nerd Font Mono", ".SystemUIFont"],
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 50,
  },
  "file_finder": {
    "include_ignored": "all",
  },
  "relative_line_numbers": "wrapped",
  "icon_theme": "Material Icon Theme",
  "show_edit_predictions": true,
  "agent": {
    "dock": "right",
    "favorite_models": [
      {
        "provider": "anthropic",
        "model": "claude-haiku-4-5-latest",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-thinking-latest",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-latest",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-latest",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-thinking-latest",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-haiku-4-5-thinking-latest",
        "enable_thinking": false,
      },
      {
        "provider": "ollama",
        "model": "gpt-oss:latest",
        "enable_thinking": true,
      },
      {
        "provider": "ollama",
        "model": "qwen3.5:9b",
        "enable_thinking": true,
      },
      {
        "provider": "ollama",
        "model": "gemma4:e4b",
        "enable_thinking": true,
      },
    ],
    "tool_permissions": {
      "tools": {
        "restore_file_from_disk": {
          "default": "allow",
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://docs\\.rs",
            },
            {
              "pattern": "^https?://testcontainers\\.org",
            },
          ],
        },
        "mcp:mcp-server-context7:query-docs": {
          "default": "allow",
        },
        "create_directory": {
          "default": "allow",
        },
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^cargo\\s",
            },
            {
              "pattern": "^grep\\s",
            },
            {
              "pattern": "^ls\\s",
            },
            {
              "pattern": "^cat\\s",
            },
            {
              "pattern": "^find\\s+fullstack\\-rust\\-react\\-template(\\s|$)",
            },
          ],
        },
      },
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "ollama",
      "model": "qwen3.5:9b",
    },
    "enabled": true,
    "button": true,
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/prof",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/.benchmarks",
    "**/report",
    "**/node_modules",
  ],
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true,
  },
  "ui_font_size": 18,
  "buffer_font_size": 15,
  "ui_font_weight": 100,
  "buffer_font_weight": 100,
  "buffer_font_family": "Hack Nerd Font",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Custom VSCode Dark Modern",
  },
  "preferred_line_length": 90,
  "show_wrap_guides": true,
  "wrap_guides": [90, 120],
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "edit_predictions": {
    "disabled_globs": [".env", ".pyc", ".venv"],
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
    "cspell": {
      "settings": {
        "dictionaries": ["custom"],
        "dictionaryDefinitions": [{ "name": "custom", "path": "./.cspell_dict.txt" }],
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"],
      },
    },
  },
  "vertical_scroll_margin": 10,
  "format_on_save": "off",
  "use_autoclose": true,
  "tab_size": 4,
  "colorize_brackets": true,
  "edit_predictions_disabled_in": ["all"],
  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "semantic_token_rules": [
      // ==========================================
      // 1. THE NUCLEAR RUST OVERRIDES
      // ==========================================
      // These are at the top to guarantee they don't get overwritten
      //
      { "token_type": "trait", "foreground_color": "#4EC9B0" },
      { "token_type": "derive", "foreground_color": "#4EC9B0" },
      { "token_type": "builtinAttribute", "foreground_color": "#569CD6" },
      { "token_type": "attribute", "foreground_color": "#DCDCAA" },
      { "token_type": "deriveHelper", "foreground_color": "#C586C0" },
      { "token_type": "toolModule", "foreground_color": "#4EC9B0" },
      { "token_type": "module", "foreground_color": "#4EC9B0" },

      { "token_type": "deriveHelper", "style": ["type"] },
      { "token_type": "trait", "style": ["type"] },

      // ==========================================
      // 2. BASE TOKENS & MODIFIERS
      // ==========================================
      { "token_modifiers": ["mutable"], "underline": true },
      { "token_modifiers": ["readonly"], "style": ["readonly"] },
      { "token_modifiers": ["deprecated"], "strikethrough": true },
      {
        "token_type": "unresolvedReference",
        "style": ["unresolved_reference"],
      },
      { "token_type": "namespace", "style": ["namespace", "type"] },
      { "token_type": "type", "style": ["type"] },
      { "token_type": "class", "style": ["class", "type"] },
      { "token_type": "enum", "style": ["enum", "type"] },
      { "token_type": "interface", "style": ["interface", "type"] },
      { "token_type": "struct", "style": ["struct", "type"] },
      { "token_type": "parameter", "style": ["parameter", "variable"] },
      { "token_type": "modifier", "style": ["modifier"] },
      { "token_type": "variable", "style": ["variable"] },
      { "token_type": "property", "style": ["property", "attribute"] },
      { "token_type": "function", "style": ["function"] },
      { "token_type": "method", "style": ["function.method", "function"] },
      { "token_type": "comment", "style": ["comment"] },
      { "token_type": "string", "style": ["string"] },
      { "token_type": "number", "style": ["number"] },
      { "token_type": "operator", "style": ["operator"] },
      { "token_type": "regexp", "style": ["string.regex"] },
      { "token_type": "invalid", "style": ["invalid"] },
      { "token_type": "character", "style": ["character"] },

      // ==========================================
      // 3. RUST SPECIFIC TOKENS
      // ==========================================
      { "token_type": "union", "style": ["union", "type"] },
      { "token_type": "boolean", "style": ["boolean"] },
      { "token_type": "typeAlias", "style": ["type_alias", "type"] },
      { "token_type": "escapeSequence", "style": ["string.escape"] },
      { "token_type": "formatSpecifier", "style": ["keyword"] },
      { "token_type": "macro", "foreground_color": "#569CD6" },
      { "token_type": "macroBang", "foreground_color": "#569CD6" },
      { "token_type": "builtinType", "style": ["builtin_type", "type"] },
      {
        "token_type": "constParameter",
        "style": ["const_parameter", "parameter", "constant"],
      },
      { "token_type": "enumMember", "style": ["variant"] },
      { "token_type": "generic", "style": ["generic", "type"] },
      { "token_type": "label", "style": ["label"] },
      { "token_type": "lifetime", "style": ["lifetime", "keyword"] },
      { "token_type": "selfKeyword", "style": ["keyword"] },
      { "token_type": "selfTypeKeyword", "style": ["self_type", "keyword"] },
      { "token_type": "toolModule", "style": ["tool_module", "namespace"] },
      { "token_type": "typeParameter", "style": ["parameter", "variable"] },
      { "token_modifiers": ["constant"], "style": ["constant"] },
      { "token_modifiers": ["consuming"], "style": ["consuming"] },
      { "token_modifiers": ["crateRoot"], "style": ["crate_root", "keyword"] },
      {
        "token_modifiers": ["documentation"],
        "style": ["documentation", "comment.doc"],
      },
      {
        "token_modifiers": ["intraDocLink"],
        "style": ["intra_doc_link", "link_uri", "link_text"],
      },
      { "token_modifiers": ["library"], "style": ["library"] },
      { "token_modifiers": ["unsafe"], "style": ["unsafe"] },
      { "token_modifiers": ["readonly"], "style": ["readonly"] },

      // ==========================================
      // 4. COMMON C++ / MARKUP
      // ==========================================
      {
        "token_type": "source.cpp keyword.operator.new",
        "style": ["keyword.control", "keyword"],
      },
      {
        "token_type": "keyword.operator.delete",
        "style": ["keyword.control", "keyword"],
      },
      {
        "token_type": "keyword.other.using",
        "style": ["keyword.control", "keyword"],
      },
      {
        "token_type": "keyword.other.directive.using",
        "style": ["keyword.control", "keyword"],
      },
      {
        "token_type": "keyword.other.operator",
        "style": ["keyword.control", "keyword"],
      },
      {
        "token_type": "entity.name.operator",
        "style": ["keyword.control", "keyword"],
      },
      { "token_type": "markup.underline", "underline": true },
      {
        "token_type": "markup.bold",
        "foreground_color": "#569CD6",
        "font_weight": "bold",
      },
      {
        "token_type": "markup.heading",
        "foreground_color": "#569CD6",
        "font_weight": "bold",
      },
      { "token_type": "markup.italic", "font_style": "italic" },
      { "token_type": "markup.strikethrough", "strikethrough": true },
      { "token_type": "markup.inserted", "foreground_color": "#B5CEA8" },
      { "token_type": "markup.deleted", "foreground_color": "#CE9178" },
      { "token_type": "markup.changed", "foreground_color": "#569CD6" },
      { "token_type": "markup.inline.raw", "foreground_color": "#CE9178" },

      // ==========================================
      // 5. KEYWORDS & CONTROL FLOW (ORDER MATTERS)
      // ==========================================
      { "token_modifiers": ["controlFlow"], "style": ["keyword.control"] }, // Purple 'if/match'
      { "token_modifiers": ["async"], "style": ["keyword.async", "keyword"] }, // Purple 'await'
      { "token_type": "keyword", "style": ["keyword"] }, // Blue 'let'
    ],
  },
  "languages": {
    "TypeScript": {
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
    "Python": {
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true,
      },
      "formatter": { "language_server": { "name": "ruff" } },
      "language_servers": ["!pyright", "ty", "ruff"],
    },
    "Markdown": {
      "soft_wrap": "editor_width",
    },
    "JSON": {
      "tab_size": 2,
    },
    "JSONC": {
      "tab_size": 2,
    },
    "YAML": {
      "tab_size": 2,
    },
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "tab_bar": {
    "show": true,
  },
  "scrollbar": {
    "show": "auto",
  },
  "file_types": {
    "PHP": ["*.php", "*.module", "*.theme"],
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "tailwindcss": ["*.css"],
    "html": ["*.twig"],
    "Markdown": ["*.md", "*TODO*"],
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "language_models": {
    "openai_compatible": {
      "vLLM": {
        "api_url": "http://127.0.0.1:39119",
        "available_models": [
          {
            "name": "AxionML/Qwen3.5-9B-NVFP4",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
    "ollama": {
      "api_url": "http://localhost:11434",
      "available_models": [
        {
          "name": "gpt-oss:latest",
          "display_name": "GPT OSS 20B",
          "max_tokens": 32000,
          "supports_thinking": true,
          "supports_tools": true,
          "supports_images": false,
          "keep_alive": 300,
        },
        {
          "name": "qwen3.5:9b",
          "display_name": "qwen 3.5 9b",
          "max_tokens": 90000,
          "supports_thinking": true,
          "supports_tools": true,
          "supports_images": true,
          "keep_alive": 300,
        },
        {
          "name": "gemma4:e4b",
          "display_name": "gemma4:e4b",
          "max_tokens": 128000,
          "supports_thinking": true,
          "supports_tools": true,
          "supports_images": true,
          "keep_alive": 300,
        },
      ],
    },
  },
}
